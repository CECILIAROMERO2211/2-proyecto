@model BienesRaicesWeb.Models.Propiedad
@{
    ViewData["Title"] = Model.Titulo;
}

<div class="mb-4">
    <a asp-controller="Propiedades" asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i> Volver al catálogo</a>
</div>

<div class="card shadow border-0 rounded-4 overflow-hidden">
    <div class="row g-0">
        <div class="col-lg-7">
            <img src="@Model.ImagenUrl" class="img-fluid w-100 h-100" alt="@Model.Titulo" style="object-fit: cover; min-height: 400px;">
        </div>
        <div class="col-lg-5 p-5 d-flex flex-column justify-content-between">
            <div>
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="badge bg-primary px-3 py-2 rounded-pill fs-6">@Model.Tipo</span>
                    <h3 class="text-success fw-bold mb-0">$@Model.Precio.ToString("N0") MXN</h3>
                </div>
                <h2 class="fw-bold mb-2">@Model.Titulo</h2>
                <p class="text-muted"><i class="bi bi-geo-alt-fill text-danger me-1"></i> @Model.Ubicacion</p>
                <hr />
                <h5 class="fw-semibold mt-4 mb-2">Descripción de la Propiedad</h5>
                <p class="text-secondary lh-lg">@Model.Descripcion</p>
                
                @if (Model.Tipo != "Terreno")
                {
                    <div class="row text-center my-4 g-2">
                        <div class="col-4">
                            <div class="p-3 bg-light rounded-3">
                                <i class="bi bi-house-door fs-4 text-primary d-block mb-1"></i>
                                <span class="fw-bold d-block">@Model.Habitaciones</span>
                                <small class="text-muted">Habitaciones</small>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="p-3 bg-light rounded-3">
                                <i class="bi bi-droplet fs-4 text-primary d-block mb-1"></i>
                                <span class="fw-bold d-block">@Model.Banos</span>
                                <small class="text-muted">Baños</small>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="p-3 bg-light rounded-3">
                                <i class="bi bi-aspect-ratio fs-4 text-primary d-block mb-1"></i>
                                <span class="fw-bold d-block">@Model.MetrosCuadrados m²</span>
                                <small class="text-muted">Área</small>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="mt-4 pt-3 border-top">
                <button class="btn btn-primary btn-lg w-100 fw-bold shadow-sm"><i class="bi bi-calendar-check me-2"></i> Agendar Visita</button>
            </div>
        </div>
    </div>
</div>