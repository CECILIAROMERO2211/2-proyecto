@model IEnumerable<BienesRaicesWeb.Models.Propiedad>

@using System.Globalization
@using System.Linq

@{
    ViewData["Title"] = "Explora Propiedades";

    string tipoSeleccionado =
        ViewBag.TipoSeleccionado as string ?? "Todos";

    /*
     * Si el controlador no envía un modelo, se utiliza una lista vacía.
     * Esto evita la NullReferenceException al recorrer las propiedades.
     */
    var propiedades = (
        Model ??
        Enumerable.Empty<BienesRaicesWeb.Models.Propiedad>()
    ).ToList();

    var culturaMexicana = new CultureInfo("es-MX");

    var vendedores = new[]
    {
        new
        {
            Nombre = "Valeria Domínguez",
            Foto = "https://images.unsplash.com/photo-1580489944761-15a19d654956?w=150&h=150&fit=crop&q=80",
            Descripcion = "Especialista en propiedades residenciales con más de 10 años ayudando a familias.",
            Calificacion = "4.95",
            Resenas = "128"
        },
        new
        {
            Nombre = "Carlos Mendoza",
            Foto = "https://images.unsplash.com/photo-1560250097-0b93528c311a?w=150&h=150&fit=crop&q=80",
            Descripcion = "Experto en inversiones y preventas. Te asesoro financieramente para obtener la mejor rentabilidad.",
            Calificacion = "4.88",
            Resenas = "95"
        },
        new
        {
            Nombre = "Sofía Ríos",
            Foto = "https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=150&h=150&fit=crop&q=80",
            Descripcion = "Arquitecta y asesora inmobiliaria. Te ayudo a visualizar el verdadero potencial de cada espacio.",
            Calificacion = "5.0",
            Resenas = "42"
        },
        new
        {
            Nombre = "Javier Ortiz",
            Foto = "https://images.unsplash.com/photo-1519085360753-af0119f7cbe7?w=150&h=150&fit=crop&q=80",
            Descripcion = "Especialista en negociaciones inmobiliarias rápidas, seguras y efectivas.",
            Calificacion = "4.75",
            Resenas = "210"
        }
    };

    int contadorVendedores = 0;

    const string imagenPredeterminada =
        "https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=1200&q=80";
}

<style>
    /* =========================================================
       TARJETAS DE PROPIEDADES
    ========================================================= */

    .property-card {
        border: none !important;
        border-radius: 12px;
        background-color: transparent;
        transition:
            transform 0.2s ease,
            box-shadow 0.2s ease;
    }

    .property-card:hover {
        transform: translateY(-4px);
    }

    .property-image-container {
        overflow: hidden;
        border-radius: 14px;
        background-color: #eeeeee;
    }

    .property-img {
        display: block;
        width: 100%;
        height: 280px;
        object-fit: cover;
        border-radius: 14px;
        margin-bottom: 12px;
        cursor: pointer;
        transition:
            transform 0.25s ease,
            filter 0.25s ease;
    }

    .property-img:hover {
        transform: scale(1.015);
        filter: brightness(0.92);
    }

    /* =========================================================
       BARRA DE BÚSQUEDA
    ========================================================= */

    .search-pill {
        padding: 10px 20px;
        background: #ffffff;
        border: 1px solid #e2e2e2;
        border-radius: 40px;
        box-shadow: 0 6px 16px rgba(0, 0, 0, 0.08);
    }

    .search-input {
        border: none !important;
        background: transparent !important;
        box-shadow: none !important;
        font-weight: 500;
    }

    .search-label {
        display: block;
        margin-bottom: 2px;
        color: #222222;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .btn-search {
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        width: 48px;
        height: 48px;
        border: none;
        border-radius: 50%;
        background-color: #ff385c;
        color: #ffffff;
        transition:
            background-color 0.2s ease,
            transform 0.2s ease;
    }

    .btn-search:hover {
        background-color: #d90b3e;
        color: #ffffff;
        transform: scale(1.04);
    }

    /* =========================================================
       MENSAJE SIN RESULTADOS
    ========================================================= */

    .empty-results {
        width: 100%;
        padding: 70px 25px;
        border: 1px solid #e5e5e5;
        border-radius: 18px;
        background-color: #ffffff;
        text-align: center;
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.05);
    }

    .empty-results-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 72px;
        height: 72px;
        margin: 0 auto 20px;
        border-radius: 50%;
        background-color: #fff0f3;
        color: #ff385c;
        font-size: 2rem;
    }

    /* =========================================================
       INFORMACIÓN DE LA TARJETA
    ========================================================= */

    .card-title-location {
        margin: 0;
        color: #222222;
        font-size: 1rem;
        font-weight: 600;
    }

    .card-subtitle-desc {
        color: #717171;
        font-size: 0.95rem;
    }

    .card-price {
        margin-top: 6px;
        color: #222222;
        font-size: 1rem;
        font-weight: 600;
    }

    .heart-btn {
        border: none;
        background: transparent;
        color: rgba(0, 0, 0, 0.5);
        transition: transform 0.2s ease;
        z-index: 5;
    }

    .heart-btn:hover {
        transform: scale(1.1);
    }

    .heart-btn svg {
        fill: rgba(0, 0, 0, 0.4);
        stroke: #ffffff;
        stroke-width: 2;
    }

    /* =========================================================
       VENTANA EMERGENTE
    ========================================================= */

    .property-modal-content {
        overflow: hidden;
        border: none;
        border-radius: 24px;
        box-shadow: 0 25px 70px rgba(0, 0, 0, 0.28);
    }

    .property-modal-header {
        padding: 22px 25px 12px;
        border: none;
    }

    .property-modal-body {
        padding: 15px 25px 28px;
    }

    .modal-gallery-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 12px;
        height: 400px;
        border-radius: 18px;
        overflow: hidden;
        background-color: #eeeeee;
    }

    .modal-main-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .modal-side-imgs {
        display: grid;
        grid-template-rows: 1fr 1fr;
        gap: 12px;
    }

    .modal-side-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .modal-property-type {
        display: inline-block;
        padding: 6px 14px;
        margin-bottom: 10px;
        border-radius: 999px;
        background-color: #fff0f3;
        color: #ff385c;
        font-size: 0.85rem;
        font-weight: 700;
    }

    .modal-property-title {
        margin: 0;
        color: #222222;
        font-size: 1.75rem;
        font-weight: 800;
        line-height: 1.25;
    }

    .modal-property-location {
        margin: 5px 0 0;
        color: #555555;
        font-size: 1.05rem;
        font-weight: 600;
    }

    /* =========================================================
       PERFIL DEL VENDEDOR
    ========================================================= */

    .seller-profile {
        display: flex;
        align-items: flex-start;
        padding: 24px 0;
        margin-top: 16px;
        margin-bottom: 24px;
        border-top: 1px solid #ebebeb;
        border-bottom: 1px solid #ebebeb;
    }

    .seller-avatar {
        width: 56px;
        height: 56px;
        margin-right: 16px;
        border-radius: 50%;
        object-fit: cover;
    }

    .seller-info h4 {
        margin: 0;
        color: #222222;
        font-size: 1.15rem;
        font-weight: 700;
    }

    .seller-info p {
        margin: 4px 0 0;
        color: #717171;
        font-size: 0.95rem;
        line-height: 1.4;
    }

    .seller-info .seller-stats-line {
        margin-top: 8px;
        font-size: 0.9rem;
    }

    .seller-info .stars {
        color: #222222;
        font-weight: 600;
    }

    /* =========================================================
       CARACTERÍSTICAS
    ========================================================= */

    .property-features {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
        margin: 24px 0;
    }

    .property-feature {
        padding: 15px 10px;
        border: 1px solid #e5e5e5;
        border-radius: 14px;
        background-color: #ffffff;
        text-align: center;
    }

    .property-feature strong {
        display: block;
        color: #222222;
        font-size: 1.05rem;
    }

    .property-feature span {
        display: block;
        margin-top: 4px;
        color: #777777;
        font-size: 0.8rem;
    }

    /* =========================================================
       PRECIO Y DESCRIPCIÓN
    ========================================================= */

    .modal-price-box {
        position: sticky;
        top: 20px;
        padding: 24px;
        border: 1px solid #e2e2e2;
        border-radius: 16px;
        background-color: #ffffff;
        box-shadow: 0 6px 16px rgba(0, 0, 0, 0.06);
    }

    .modal-price-box span {
        display: block;
        color: #707070;
        font-size: 0.9rem;
    }

    .modal-price-box strong {
        display: block;
        margin-top: 5px;
        color: #222222;
        font-size: 1.55rem;
    }

    .custom-modal-content {
        padding: 18px;
        margin-top: 20px;
        border-left: 4px solid #ff385c;
        border-radius: 8px;
        background-color: #fff8fa;
    }

    .custom-modal-content h4 {
        margin-bottom: 10px;
        color: #222222;
        font-size: 1.05rem;
        font-weight: 800;
    }

    .custom-modal-content p {
        margin: 0;
        color: #555555;
        line-height: 1.65;
        white-space: pre-line;
    }

    .modal-contact-button {
        width: 100%;
        padding: 13px;
        margin-top: 20px;
        border: none;
        border-radius: 12px;
        background-color: #ff385c;
        color: #ffffff;
        font-weight: 700;
        transition: background-color 0.2s ease;
    }

    .modal-contact-button:hover {
        background-color: #d90b3e;
    }

    .modal-map-container {
        margin-top: 30px;
    }

    .modal-map-container h4 {
        margin-bottom: 15px;
        color: #222222;
        font-weight: 800;
    }

    @@media (max-width: 767px) {
        .search-pill {
            flex-direction: column;
            align-items: stretch !important;
            gap: 12px;
            border-radius: 24px;
        }

        .search-pill .border-end {
            border-right: none !important;
            border-bottom: 1px solid #eeeeee;
            padding-bottom: 12px;
        }

        .search-pill .ps-2 {
            padding-left: 0 !important;
        }

        .btn-search {
            width: 100%;
            border-radius: 12px;
        }

        .property-img {
            height: 240px;
        }

        .modal-gallery-grid {
            grid-template-columns: 1fr;
            height: auto;
            gap: 8px;
        }

        .modal-main-img {
            height: 260px;
        }

        .modal-side-imgs {
            display: flex;
            gap: 8px;
        }

        .modal-side-img {
            width: 50%;
            height: 120px;
        }

        .property-features {
            grid-template-columns: 1fr;
        }

        .modal-property-title {
            font-size: 1.4rem;
        }
    }
</style>

<div class="container-fluid px-4 py-4"
     style="max-width: 1400px;">

    <!-- Barra de filtros -->
    <div class="row justify-content-center mb-5">
        <div class="col-12 col-md-9 col-lg-7">

            <form asp-controller="Propiedades"
                  asp-action="Index"
                  method="get"
                  class="search-pill d-flex align-items-center">

                <div class="flex-grow-1 px-3 border-end">
                    <label for="tipo"
                           class="search-label">
                        Tipo de propiedad
                    </label>

                    <select id="tipo"
                            name="tipo"
                            class="form-control search-input px-0">

                        @if (tipoSeleccionado == "Todos")
                        {
                            <option value="Todos" selected>
                                Cualquiera
                            </option>
                        }
                        else
                        {
                            <option value="Todos">
                                Cualquiera
                            </option>
                        }

                        @if (tipoSeleccionado == "Casa")
                        {
                            <option value="Casa" selected>
                                Casas
                            </option>
                        }
                        else
                        {
                            <option value="Casa">
                                Casas
                            </option>
                        }

                        @if (tipoSeleccionado == "Departamento")
                        {
                            <option value="Departamento" selected>
                                Departamentos
                            </option>
                        }
                        else
                        {
                            <option value="Departamento">
                                Departamentos
                            </option>
                        }

                        @if (tipoSeleccionado == "Terreno")
                        {
                            <option value="Terreno" selected>
                                Terrenos
                            </option>
                        }
                        else
                        {
                            <option value="Terreno">
                                Terrenos
                            </option>
                        }
                    </select>
                </div>

                <div class="flex-grow-1 px-3">
                    <label for="precioMax"
                           class="search-label">
                        Presupuesto máximo
                    </label>

                    <input id="precioMax"
                           type="number"
                           name="precioMax"
                           min="0"
                           step="1000"
                           class="form-control search-input px-0"
                           placeholder="Ej. 5000000"
                           value="@ViewBag.PrecioMaximo" />
                </div>

                <div class="ps-2">
                    <button type="submit"
                            class="btn-search shadow-sm"
                            aria-label="Buscar propiedades">

                        <svg viewBox="0 0 32 32"
                             xmlns="http://www.w3.org/2000/svg"
                             aria-hidden="true"
                             style="
                                display: block;
                                fill: none;
                                height: 16px;
                                width: 16px;
                                stroke: currentColor;
                                stroke-width: 4;
                                overflow: visible;
                             ">

                            <path d="
                                m13 24
                                c6.0751322 0 11-4.9248678 11-11
                                0-6.07513225-4.9248678-11-11-11
                                -6.07513225 0-11 4.92486775-11 11
                                0 6.0751322 4.92486775 11 11 11
                                zm8-3 9 9
                            ">
                            </path>
                        </svg>
                    </button>
                </div>
            </form>

        </div>
    </div>

    <!-- Catálogo -->
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-xl-4 g-4">

        @if (!propiedades.Any())
        {
            <div class="col-12 w-100">
                <div class="empty-results">

                    <div class="empty-results-icon"
                         aria-hidden="true">
                        ⌂
                    </div>

                    <h2 class="h4 fw-bold">
                        No hay propiedades disponibles
                    </h2>

                    <p class="text-muted mb-4">
                        No encontramos propiedades registradas con los
                        filtros seleccionados.
                    </p>

                    <a asp-controller="Propiedades"
                       asp-action="Index"
                       class="btn btn-outline-dark rounded-pill px-4">
                        Limpiar filtros
                    </a>
                </div>
            </div>
        }
        else
        {
            @foreach (var item in propiedades)
            {
                var vendedorActual =
                    vendedores[
                        contadorVendedores % vendedores.Length
                    ];

                contadorVendedores++;

                string imagenPrincipal =
                    string.IsNullOrWhiteSpace(item.ImagenUrl)
                        ? imagenPredeterminada
                        : Url.Content(item.ImagenUrl);

                string titulo =
                    string.IsNullOrWhiteSpace(item.Titulo)
                        ? "Propiedad disponible"
                        : item.Titulo;

                string ubicacion =
                    string.IsNullOrWhiteSpace(item.Ubicacion)
                        ? "Ubicación no especificada"
                        : item.Ubicacion;

                string descripcion =
                    string.IsNullOrWhiteSpace(item.Descripcion)
                        ? "Esta propiedad todavía no cuenta con una descripción."
                        : item.Descripcion;

                string tipo =
                    string.IsNullOrWhiteSpace(item.Tipo)
                        ? "Propiedad"
                        : item.Tipo;

                <div class="col">
                    <article class="card property-card h-100">

                        <div class="position-relative property-image-container">

                            <img src="@imagenPrincipal"
                                 class="card-img-top property-img"
                                 alt="Imagen de @titulo"
                                 role="button"
                                 tabindex="0"
                                 data-bs-toggle="modal"
                                 data-bs-target="#propertyModal"
                                 data-id="@item.Id"
                                 data-title="@titulo"
                                 data-description="@descripcion"
                                 data-type="@tipo"
                                 data-location="@ubicacion"
                                 data-price="@item.Precio.ToString("N2", culturaMexicana)"
                                 data-image="@imagenPrincipal"
                                 data-image2="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=800&q=80"
                                 data-image3="https://images.unsplash.com/photo-1512917774080-9991f1c4c750?w=800&q=80"
                                 data-habitaciones="@item.Habitaciones"
                                 data-banos="@item.Banos"
                                 data-metros="@item.MetrosCuadrados"
                                 data-vendedor-nombre="@vendedorActual.Nombre"
                                 data-vendedor-foto="@vendedorActual.Foto"
                                 data-vendedor-desc="@vendedorActual.Descripcion"
                                 data-vendedor-calif="@vendedorActual.Calificacion"
                                 data-vendedor-resenas="@vendedorActual.Resenas" />

                            <div class="
                                position-absolute
                                top-0
                                start-0
                                m-3
                                badge
                                bg-white
                                text-dark
                                shadow-sm
                                px-2
                                py-1
                            "
                                 style="
                                    border-radius: 8px;
                                    font-weight: 600;
                                 ">
                                @tipo
                            </div>

                            <button type="button"
                                    class="
                                        position-absolute
                                        top-0
                                        end-0
                                        m-2
                                        heart-btn
                                        p-1
                                    "
                                    aria-label="Agregar @titulo a favoritos">

                                <svg viewBox="0 0 32 32"
                                     xmlns="http://www.w3.org/2000/svg"
                                     aria-hidden="true"
                                     style="
                                        display: block;
                                        height: 24px;
                                        width: 24px;
                                     ">

                                    <path d="
                                        m16 28
                                        c7-4.733 14-10 14-17
                                        0-1.792-.683-3.583-2.05-4.95
                                        -1.367-1.366-3.158-2.05-4.95-2.05
                                        -1.791 0-3.583.684-4.949 2.05
                                        l-2.051 2.051-2.05-2.051
                                        c-1.367-1.366-3.158-2.05-4.95-2.05
                                        -1.791 0-3.583.684-4.949 2.05
                                        -1.367 1.367-2.051 3.158-2.051 4.95
                                        0 7 7 12.267 14 17z
                                    ">
                                    </path>
                                </svg>
                            </button>
                        </div>

                        <div class="card-body p-0">

                            <div class="
                                d-flex
                                justify-content-between
                                align-items-center
                                mb-1
                            ">

                                <h2 class="
                                    card-title-location
                                    text-truncate
                                    h5
                                ">
                                    @ubicacion
                                </h2>

                                <span style="
                                    font-size: 0.95rem;
                                    white-space: nowrap;
                                ">

                                    <svg viewBox="0 0 32 32"
                                         xmlns="http://www.w3.org/2000/svg"
                                         aria-hidden="true"
                                         style="
                                            display: inline-block;
                                            height: 12px;
                                            width: 12px;
                                            fill: currentColor;
                                            margin-bottom: 2px;
                                         ">

                                        <path d="
                                            M15.094 1.579
                                            l-4.124 8.885
                                            -9.86 1.27
                                            a1 1 0 0 0-.542 1.736
                                            l7.293 6.565
                                            -1.965 9.852
                                            a1 1 0 0 0 1.483 1.061
                                            L16 25.951
                                            l8.625 4.997
                                            a1 1 0 0 0 1.482-1.06
                                            l-1.965-9.853
                                            7.293-6.565
                                            a1 1 0 0 0-.541-1.735
                                            l-9.86-1.271
                                            -4.127-8.885
                                            a1 1 0 0 0-1.814 0z
                                        ">
                                        </path>
                                    </svg>

                                    @vendedorActual.Calificacion
                                </span>
                            </div>

                            <p class="card-subtitle-desc text-truncate mb-1">
                                @titulo
                            </p>

                            <p class="card-price mb-0">
                                @item.Precio.ToString(
                                    "C2",
                                    culturaMexicana
                                )

                                <span class="text-muted"
                                      style="font-weight: 400;">
                                    MXN total
                                </span>
                            </p>
                        </div>
                    </article>
                </div>
            }
        }
    </div>
</div>

<!-- Ventana emergente -->
<div class="modal fade"
     id="propertyModal"
     tabindex="-1"
     aria-labelledby="propertyModalTitle"
     aria-hidden="true">

    <div class="
        modal-dialog
        modal-xl
        modal-dialog-centered
        modal-dialog-scrollable
    ">

        <div class="modal-content property-modal-content">

            <div class="modal-header property-modal-header">

                <div>
                    <span id="modalPropertyType"
                          class="modal-property-type">
                        Propiedad
                    </span>

                    <h2 id="propertyModalTitle"
                        class="modal-property-title">
                        Detalles de la propiedad
                    </h2>
                </div>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal"
                        aria-label="Cerrar">
                </button>
            </div>

            <div class="modal-body property-modal-body">

                <div class="modal-gallery-grid mb-4">

                    <img id="modalPropertyImage"
                         src="@imagenPredeterminada"
                         class="modal-main-img"
                         alt="Imagen principal de la propiedad" />

                    <div class="modal-side-imgs">

                        <img id="modalPropertyImage2"
                             src="@imagenPredeterminada"
                             class="modal-side-img"
                             alt="Segunda imagen de la propiedad" />

                        <img id="modalPropertyImage3"
                             src="@imagenPredeterminada"
                             class="modal-side-img"
                             alt="Tercera imagen de la propiedad" />

                    </div>
                </div>

                <div class="row g-4">

                    <div class="col-12 col-lg-8">

                        <p id="modalPropertyLocation"
                           class="modal-property-location">
                        </p>

                        <div class="seller-profile">

                            <img id="modalSellerAvatar"
                                 src=""
                                 class="seller-avatar"
                                 alt="Foto del vendedor" />

                            <div class="seller-info">

                                <h4 id="modalSellerName">
                                    Agente inmobiliario
                                </h4>

                                <p id="modalSellerDesc">
                                    Información del agente.
                                </p>

                                <p class="seller-stats-line">

                                    <span class="stars"
                                          id="modalSellerStars">
                                        ★ 0.0
                                    </span>

                                    (<span id="modalSellerReviews">0</span>
                                    reseñas)
                                </p>
                            </div>
                        </div>

                        <div class="property-features">

                            <div id="featureHabitaciones"
                                 class="property-feature">

                                <strong id="modalHabitaciones">
                                    0
                                </strong>

                                <span>Habitaciones</span>
                            </div>

                            <div id="featureBanos"
                                 class="property-feature">

                                <strong id="modalBanos">
                                    0
                                </strong>

                                <span>Baños</span>
                            </div>

                            <div id="featureMetros"
                                 class="property-feature">

                                <strong id="modalMetros">
                                    0 m²
                                </strong>

                                <span>Superficie</span>
                            </div>
                        </div>

                        <div class="custom-modal-content">

                            <h4>
                                Descripción de la propiedad
                            </h4>

                            <p id="modalPropertyDescription">
                            </p>
                        </div>

                        <div class="modal-map-container">

                            <h4>Ubicación</h4>

                            <iframe id="modalMapIframe"
                                    title="Mapa de ubicación de la propiedad"
                                    width="100%"
                                    height="300"
                                    style="
                                        border: 0;
                                        border-radius: 12px;
                                    "
                                    allowfullscreen
                                    loading="lazy"
                                    referrerpolicy="
                                        no-referrer-when-downgrade
                                    ">
                            </iframe>
                        </div>
                    </div>

                    <div class="col-12 col-lg-4">

                        <div class="modal-price-box">

                            <span>Precio total</span>

                            <strong id="modalPropertyPrice">
                                $0.00 MXN
                            </strong>

                            <a asp-controller="Home"
                               asp-action="Contacto"
                               class="
                                   modal-contact-button
                                   d-block
                                   text-center
                                   text-decoration-none
                               ">
                                Contactar al vendedor
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const propertyModal =
            document.getElementById("propertyModal");

        if (!propertyModal) {
            return;
        }

        propertyModal.addEventListener(
            "show.bs.modal",
            function (event) {
                const selectedImage = event.relatedTarget;

                if (!selectedImage) {
                    return;
                }

                const title =
                    selectedImage.getAttribute("data-title") ||
                    "Propiedad disponible";

                const description =
                    selectedImage.getAttribute("data-description") ||
                    "Sin descripción disponible.";

                const type =
                    selectedImage.getAttribute("data-type") ||
                    "Propiedad";

                const location =
                    selectedImage.getAttribute("data-location") ||
                    "México";

                const price =
                    selectedImage.getAttribute("data-price") ||
                    "0.00";

                const image1 =
                    selectedImage.getAttribute("data-image") ||
                    "";

                const image2 =
                    selectedImage.getAttribute("data-image2") ||
                    image1;

                const image3 =
                    selectedImage.getAttribute("data-image3") ||
                    image1;

                const sellerName =
                    selectedImage.getAttribute(
                        "data-vendedor-nombre"
                    ) || "Agente inmobiliario";

                const sellerPhoto =
                    selectedImage.getAttribute(
                        "data-vendedor-foto"
                    ) || "";

                const sellerDescription =
                    selectedImage.getAttribute(
                        "data-vendedor-desc"
                    ) || "Asesor inmobiliario de Horizon.";

                const sellerRating =
                    selectedImage.getAttribute(
                        "data-vendedor-calif"
                    ) || "0.0";

                const sellerReviews =
                    selectedImage.getAttribute(
                        "data-vendedor-resenas"
                    ) || "0";

                const habitaciones =
                    Number.parseInt(
                        selectedImage.getAttribute(
                            "data-habitaciones"
                        ),
                        10
                    ) || 0;

                const banos =
                    Number.parseInt(
                        selectedImage.getAttribute(
                            "data-banos"
                        ),
                        10
                    ) || 0;

                const metros =
                    Number.parseInt(
                        selectedImage.getAttribute(
                            "data-metros"
                        ),
                        10
                    ) || 0;

                establecerTexto(
                    "propertyModalTitle",
                    title
                );

                establecerTexto(
                    "modalPropertyDescription",
                    description
                );

                establecerTexto(
                    "modalPropertyType",
                    type
                );

                establecerTexto(
                    "modalPropertyLocation",
                    location
                );

                establecerTexto(
                    "modalPropertyPrice",
                    "$" + price + " MXN"
                );

                establecerTexto(
                    "modalSellerName",
                    "Agente: " + sellerName
                );

                establecerTexto(
                    "modalSellerDesc",
                    sellerDescription
                );

                establecerTexto(
                    "modalSellerStars",
                    "★ " + sellerRating
                );

                establecerTexto(
                    "modalSellerReviews",
                    sellerReviews
                );

                establecerImagen(
                    "modalSellerAvatar",
                    sellerPhoto
                );

                establecerImagen(
                    "modalPropertyImage",
                    image1
                );

                establecerImagen(
                    "modalPropertyImage2",
                    image2
                );

                establecerImagen(
                    "modalPropertyImage3",
                    image3
                );

                const mapIframe =
                    document.getElementById(
                        "modalMapIframe"
                    );

                if (mapIframe) {
                    const encodedLocation =
                        encodeURIComponent(
                            location + ", México"
                        );

                    mapIframe.src =
                        "https://maps.google.com/maps?q=" +
                        encodedLocation +
                        "&output=embed";
                }

                actualizarCaracteristica(
                    "featureHabitaciones",
                    "modalHabitaciones",
                    habitaciones,
                    habitaciones.toString()
                );

                actualizarCaracteristica(
                    "featureBanos",
                    "modalBanos",
                    banos,
                    banos.toString()
                );

                actualizarCaracteristica(
                    "featureMetros",
                    "modalMetros",
                    metros,
                    metros + " m²"
                );
            }
        );

        propertyModal.addEventListener(
            "hidden.bs.modal",
            function () {
                const mapIframe =
                    document.getElementById(
                        "modalMapIframe"
                    );

                if (mapIframe) {
                    mapIframe.src = "";
                }
            }
        );

        function establecerTexto(elementId, value) {
            const element =
                document.getElementById(elementId);

            if (element) {
                element.textContent = value;
            }
        }

        function establecerImagen(elementId, source) {
            const image =
                document.getElementById(elementId);

            if (image && source) {
                image.src = source;
            }
        }

        function actualizarCaracteristica(
            containerId,
            valueId,
            value,
            formattedValue
        ) {
            const container =
                document.getElementById(containerId);

            const valueElement =
                document.getElementById(valueId);

            if (!container || !valueElement) {
                return;
            }

            if (value > 0) {
                container.style.display = "block";
                valueElement.textContent = formattedValue;
            } else {
                container.style.display = "none";
            }
        }

        document
            .querySelectorAll(".property-img")
            .forEach(function (image) {
                image.addEventListener(
                    "keydown",
                    function (event) {
                        if (
                            event.key === "Enter" ||
                            event.key === " "
                        ) {
                            event.preventDefault();
                            image.click();
                        }
                    }
                );
            });
    });
</script>