@{
    ViewData["Title"] = "Contacto";
}

<div class="container py-5" style="margin-top: 130px; font-family: 'Montserrat', sans-serif;">
    <div class="row justify-content-center">
        <div class="col-lg-6 text-center mb-5">
            <h1 style="font-family: 'Playfair Display', serif; color: #1A1A1A; font-size: 2.8rem;">Contacto</h1>
            <p class="text-muted mt-3">Permítenos acompañarte en la búsqueda de tu próximo hogar o inversión.</p>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-5">
            <form>
                <div class="mb-3">
                    <label class="form-label text-uppercase small" style="letter-spacing: 1px; font-weight: 500;">Nombre Completo</label>
                    <input type="text" class="form-control border-0 bg-light p-3" style="border-radius: 8px;">
                </div>
                <div class="mb-3">
                    <label class="form-label text-uppercase small" style="letter-spacing: 1px; font-weight: 500;">Correo Electrónico</label>
                    <input type="email" class="form-control border-0 bg-light p-3" style="border-radius: 8px;">
                </div>
                <div class="mb-4">
                    <label class="form-label text-uppercase small" style="letter-spacing: 1px; font-weight: 500;">Mensaje</label>
                    <textarea class="form-control border-0 bg-light p-3" rows="4" style="border-radius: 8px;"></textarea>
                </div>
                <button type="button" class="w-100 p-3 text-uppercase font-weight-bold" style="background: linear-gradient(135deg, #D4CFC1 0%, #BCAE93 100%); border: none; border-radius: 30px; font-size: 0.85rem; letter-spacing: 2px; font-weight: 600;">Enviar Mensaje</button>
            </form>
        </div>
    </div>
</div>