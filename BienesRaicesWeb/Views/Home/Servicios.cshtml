@{
    ViewData["Title"] = "Servicios";
}

<div class="container py-5" style="margin-top: 130px; font-family: 'Montserrat', sans-serif;">
    <div class="text-center mb-5">
        <h1 style="font-family: 'Playfair Display', serif; color: #1A1A1A; font-size: 2.8rem;">Nuestros Servicios</h1>
        <p class="text-muted mt-3" style="max-width: 600px; margin: 0 auto;">Ofrecemos soluciones integrales en el sector inmobiliario de lujo, respaldadas por un equipo de expertos expertos.</p>
    </div>

    <div class="row g-4 mt-4">
        <!-- Servicio 1 -->
        <div class="col-md-4">
            <div class="card h-100 border-0 p-4" style="background-color: #FAFAFA; border-radius: 12px;">
                <h3 style="font-family: 'Playfair Display', serif; color: #1A1A1A; font-size: 1.4rem;">Venta Residencial</h3>
                <p class="text-muted small mt-2">Promocionamos tu propiedad utilizando estrategias de marketing digital exclusivas y redes de contactos premium.</p>
            </div>
        </div>
        <!-- Servicio 2 -->
        <div class="col-md-4">
            <div class="card h-100 border-0 p-4" style="background-color: #FAFAFA; border-radius: 12px;">
                <h3 style="font-family: 'Playfair Display', serif; color: #1A1A1A; font-size: 1.4rem;">Asesoría Legal y Fiscal</h3>
                <p class="text-muted small mt-2">Garantizamos total certidumbre jurídica y optimización fiscal en cada paso de tus transacciones inmobiliarias.</p>
            </div>
        </div>
        <!-- Servicio 3 -->
        <div class="col-md-4">
            <div class="card h-100 border-0 p-4" style="background-color: #FAFAFA; border-radius: 12px;">
                <h3 style="font-family: 'Playfair Display', serif; color: #1A1A1A; font-size: 1.4rem;">Inversiones y Proyectos</h3>
                <p class="text-muted small mt-2">Identificamos oportunidades de alta plusvalía y proyectos en preventa ideales para tu portafolio patrimonial.</p>
            </div>
        </div>
    </div>
</div>